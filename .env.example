# Copy to .env and fill in (or source from Doppler). NEVER commit real values.

# A bot account's API key on the Manifold clone (used for bet/sell auth).
MANIFOLD_CLONE_API_KEY=

# Cloudflare Access service token — required on EVERY request to the clone.
CF_ACCESS_CLIENT_ID=
CF_ACCESS_CLIENT_SECRET=

# Optional: admin key, only needed to mint bot accounts / add mana yourself.
MANIFOLD_CLONE_ADMIN_API_KEY=

# Optional: local LLM endpoint for llm strategies (OpenAI-compatible, LOCAL only).
QUANTBOTS_LLM_BASE_URL=http://localhost:11434/v1
QUANTBOTS_LLM_API_KEY=ollama
QUANTBOTS_LLM_MODEL=qwen3:32b

# Optional: override the SQLite store location.
# QUANTBOTS_DB=data/quantbots.sqlite

# --- equity_options (FENCED real-options package; see equity_options/SAFETY.md) ---
# Alpaca PAPER trading + market data keys. Paper account only in this build.
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
# Optional: override the equity_options SQLite store / config locations.
# EQUITY_OPTIONS_DB=data/equity_options.sqlite
# EQUITY_OPTIONS_CONFIG=config/equity_options.yaml
# DANGER: never set this in this build — live.py refuses real-money trading without it.
# EQUITY_OPTIONS_OWNER_APPROVAL=
